generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth Models ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(SALES_REP)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  prospects    Prospect[]  @relation("ProspectOwner")
  activities   Activity[]
  followUps    FollowUp[]
  notes        Note[]
}

enum UserRole {
  ADMIN
  MANAGER
  SALES_REP
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core CRM Models ──────────────────────────────────────────────────────────

model Prospect {
  id                   String         @id @default(cuid())
  restaurantName       String
  branchName           String?
  location             String?
  area                 String?
  contactPerson        String?
  position             String?
  phone                String?
  whatsapp             String?
  email                String?
  instagram            String?
  linkedin             String?
  source               LeadSource?
  numberOfBranches     Int?
  currentPosStatus     String?
  existingSystem       String?
  estimatedDailyOrders Int?
  estimatedRevenue     Float?
  automationAppetite   Int?
  priorityScore        Int?           @default(0)
  leadOwnerId          String?
  stage                PipelineStage  @default(PROSPECT)
  lostReason           String?
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  leadOwner        User?            @relation("ProspectOwner", fields: [leadOwnerId], references: [id])
  activities       Activity[]
  followUps        FollowUp[]
  discoveryAnswers DiscoveryAnswer[]
  painPoints       PainPoint[]
  demos            Demo[]
  objections       Objection[]
  proposals        Proposal[]
  onboarding       Onboarding?
  intelligenceLog  IntelligenceLog?
  notes            Note[]
  stageHistory     StageHistory[]
}

enum PipelineStage {
  PROSPECT
  CONTACTED
  DISCOVERY_DONE
  DEMO_DONE
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
}

enum LeadSource {
  WALK_IN
  GOOGLE_MAPS
  INSTAGRAM
  LINKEDIN
  REFERRAL
  GLOVO
  UBER_EATS
  JUMIA_FOOD
  OTHER
}

// ─── Stage History ─────────────────────────────────────────────────────────────

model StageHistory {
  id          String         @id @default(cuid())
  prospectId  String
  fromStage   PipelineStage?
  toStage     PipelineStage
  changedById String?
  notes       String?
  createdAt   DateTime       @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

// ─── Activities ────────────────────────────────────────────────────────────────

model Activity {
  id         String       @id @default(cuid())
  prospectId String
  userId     String?
  type       ActivityType
  date       DateTime
  notes      String?      @db.Text
  outcome    String?      @db.Text
  nextAction String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])
}

enum ActivityType {
  WALK_IN_VISIT
  PHONE_CALL
  WHATSAPP_MESSAGE
  LINKEDIN_MESSAGE
  EMAIL
  DISCOVERY_MEETING
  DEMO
  PROPOSAL_SENT
  NEGOTIATION_MEETING
  FOLLOW_UP
  ONBOARDING_MEETING
  OTHER
}

// ─── Follow-Ups ────────────────────────────────────────────────────────────────

model FollowUp {
  id          String         @id @default(cuid())
  prospectId  String
  userId      String?
  dueDate     DateTime
  type        FollowUpType
  notes       String?        @db.Text
  status      FollowUpStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])
}

enum FollowUpType {
  CALL
  WHATSAPP
  EMAIL
  MEETING
  DEMO
  PROPOSAL_FOLLOW_UP
  CHECK_IN
  RE_ENGAGEMENT
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  RESCHEDULED
}

// ─── Discovery ─────────────────────────────────────────────────────────────────

model DiscoveryAnswer {
  id         String   @id @default(cuid())
  prospectId String
  category   String
  question   String
  answer     String?  @db.Text
  isCustom   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

// ─── Pain Points ───────────────────────────────────────────────────────────────

model PainPoint {
  id          String   @id @default(cuid())
  prospectId  String
  category    String
  description String   @db.Text
  severity    Int
  frequency   Int
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

// ─── Demos ─────────────────────────────────────────────────────────────────────

model Demo {
  id               String   @id @default(cuid())
  prospectId       String
  demoDate         DateTime
  attendees        String?
  founderPresent   Boolean  @default(false)
  featuresDemo     String?  @db.Text
  prospectFeedback String?  @db.Text
  objectionsRaised String?  @db.Text
  rating           Int?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

// ─── Objections ────────────────────────────────────────────────────────────────

model Objection {
  id            String            @id @default(cuid())
  prospectId    String
  objection     String
  category      ObjectionCategory
  responseGiven String?           @db.Text
  status        ObjectionStatus   @default(OPEN)
  resolved      Boolean           @default(false)
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

enum ObjectionCategory {
  PRICE
  EXISTING_SYSTEM
  TIMING
  THINK_ABOUT_IT
  TRUST
  FEATURES
  CONTRACT
  OTHER
}

enum ObjectionStatus {
  OPEN
  ADDRESSED
  RESOLVED
}

// ─── Proposals ─────────────────────────────────────────────────────────────────

model Proposal {
  id             String         @id @default(cuid())
  prospectId     String
  proposalDate   DateTime
  recommendedPkg String?
  value          Float?
  notes          String?        @db.Text
  expiryDate     DateTime?
  status         ProposalStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  NEGOTIATING
  ACCEPTED
  REJECTED
}

// ─── Onboarding ────────────────────────────────────────────────────────────────

model Onboarding {
  id                     String    @id @default(cuid())
  prospectId             String    @unique
  agreementConfirmed     Boolean   @default(false)
  agreementDate          DateTime?
  founderIntroduced      Boolean   @default(false)
  founderIntroDate       DateTime?
  onboardingScheduled    Boolean   @default(false)
  onboardingScheduleDate DateTime?
  setupStarted           Boolean   @default(false)
  setupStartDate         DateTime?
  setupComplete          Boolean   @default(false)
  setupCompleteDate      DateTime?
  trainingComplete       Boolean   @default(false)
  trainingCompleteDate   DateTime?
  goLive                 Boolean   @default(false)
  goLiveDate             DateTime?
  thirtyDayReview        Boolean   @default(false)
  thirtyDayReviewDate    DateTime?
  notes                  String?   @db.Text
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
}

// ─── Intelligence Log ──────────────────────────────────────────────────────────

model IntelligenceLog {
  id                  String   @id @default(cuid())
  prospectId          String   @unique
  whatsappProcess     String?  @db.Text
  mpesaProcess        String?  @db.Text
  loyaltySystem       String?  @db.Text
  desiredAutomations  String?  @db.Text
  digitalMaturity     Int?
  automationAppetite  Int?
  futureOpportunities String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  quotes   Quote[]
}

model Quote {
  id                String   @id @default(cuid())
  intelligenceLogId String
  quote             String   @db.Text
  context           String?
  date              DateTime @default(now())
  createdAt         DateTime @default(now())

  intelligenceLog IntelligenceLog @relation(fields: [intelligenceLogId], references: [id], onDelete: Cascade)
}

// ─── Notes ─────────────────────────────────────────────────────────────────────

model Note {
  id         String   @id @default(cuid())
  prospectId String
  userId     String?
  category   String?
  title      String?
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])
}
